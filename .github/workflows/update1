name: Deploy Fixed Portfolio

on:
  push:
    branches: ["main"]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: "pages-fixed"
  cancel-in-progress: true

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Fix Jekyll config and auto-detect project folders
        run: |
          cat > _config.yml <<'EOF'
          title: "Zeyad Belal - Mechatronics Engineer"
          description: "A portfolio for my robotics, mechatronics, embedded systems, and automation projects"
          url: "https://jumpedmocha3.github.io"
          baseurl: "/profile"

          author: "Zeyad Belal"
          email: "ziad5203@gmail.com"
          github_username: "JumpedMocha3"
          linkedin_username: "zeyad-belal"

          markdown: kramdown
          highlighter: rouge

          plugins:
            - jekyll-feed
            - jekyll-sitemap
            - jekyll-seo-tag

          collections:
            projects:
              output: true
              permalink: /projects/:name/

          defaults:
            - scope:
                path: ""
                type: "projects"
              values:
                layout: "project"
            - scope:
                path: ""
                type: "posts"
              values:
                layout: "post"

          navigation:
            - title: "Home"
              url: "/"
            - title: "Projects"
              url: "/projects/"
            - title: "About"
              url: "/about/"

          project_categories:
            - name: "Robotics"
              slug: "robotics"
              description: "Autonomous robots and robotic systems"
            - name: "Mechatronics"
              slug: "mechatronics"
              description: "Integration of mechanical, electrical, and software systems"
            - name: "Arduino"
              slug: "arduino"
              description: "Arduino-based projects and prototypes"
            - name: "3D Printing"
              slug: "3d-printing"
              description: "Custom 3D printed components and designs"
            - name: "IoT"
              slug: "iot"
              description: "Internet of Things devices and applications"

          models:
            supported_formats: ["stl", "obj", "gltf", "glb"]
            default_background: "#f0f0f0"
            camera_controls: true
            auto_rotate: false

          schematics:
            supported_formats: ["png", "jpg", "jpeg", "svg", "pdf"]
            zoom_enabled: true
            pan_enabled: true

          exclude:
            - Gemfile
            - Gemfile.lock
            - node_modules
            - vendor
            - vendor/bundle/
            - vendor/cache/
            - vendor/gems/
            - vendor/ruby/
            - README.md
            - LICENSE
          EOF

          cat > Gemfile <<'EOF'
          source "https://rubygems.org"

          gem "jekyll", "~> 4.3"
          gem "webrick"
          gem "jekyll-feed"
          gem "jekyll-sitemap"
          gem "jekyll-seo-tag"
          EOF

          rm -f Gemfile.lock

          rm -rf _projects
          mkdir -p _projects

          if [ -d "projects" ]; then
            for project_dir in projects/*; do
              if [ -d "$project_dir" ] && [ -f "$project_dir/index.md" ]; then
                project_name=$(basename "$project_dir")
                output_file="_projects/${project_name}.md"

                awk -v project_name="$project_name" '
                  BEGIN { front=0; done=0 }
                  NR==1 && $0=="---" { print; front=1; next }
                  front==1 && $0=="---" && done==0 {
                    print "featured_image: \"/projects/" project_name "/featured.jpg\""
                    print "project_folder: \"/projects/" project_name "\""
                    print "---"
                    front=0
                    done=1
                    next
                  }
                  { print }
                ' "$project_dir/index.md" > "$output_file"
              fi
            done
          fi

      - name: Setup Ruby
        uses: ruby/setup-ruby@v1
        with:
          ruby-version: '3.2.3'
          bundler-cache: true

      - name: Setup Pages
        id: pages
        uses: actions/configure-pages@v5

      - name: Build with Jekyll
        run: bundle exec jekyll build --baseurl "${{ steps.pages.outputs.base_path }}"
        env:
          JEKYLL_ENV: production

      - name: Upload artifact
        uses: actions/upload-pages-artifact@v3

  deploy:
    runs-on: ubuntu-latest
    needs: build

    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}

    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v5
